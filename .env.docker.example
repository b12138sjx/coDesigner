WEB_PORT=8080
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
# 与 docker.io 网络不通时，可改为例如 docker.m.daocloud.io/library/<name>:<tag>
POSTGRES_IMAGE=postgres:16-alpine
NODE_IMAGE=node:20-bookworm-slim
NGINX_IMAGE=nginx:1.27-alpine
APT_MIRROR=mirrors.aliyun.com
ALPINE_MIRROR=mirrors.aliyun.com
NPM_REGISTRY=https://registry.npmmirror.com

# 与宿主机其它端口冲突时调整（默认 15432）
POSTGRES_HOST_PORT=15432
POSTGRES_DB=codesigner
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/codesigner?schema=codesigner_auth

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=20

JWT_ACCESS_SECRET=local_access_secret_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=local_refresh_secret_change_me
JWT_REFRESH_EXPIRES_IN=7d

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_API_HOST_PORT=3001

VITE_API_BASE_URL=/api/v1
VITE_AI_API_BASE_URL=
