# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:<your_password>@localhost:5432/codesigner?schema=codesigner_auth"

# Server
PORT=3000

# CORS (comma separated)
CORS_ORIGIN="http://localhost:5173"

# Rate limit
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=20

# JWT
JWT_ACCESS_SECRET="replace_with_long_random_access_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace_with_long_random_refresh_secret"
JWT_REFRESH_EXPIRES_IN="7d"
